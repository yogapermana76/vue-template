# ===========================================
# Environment Configuration
# Copy this file to .env.local for local development
# ===========================================

# App Configuration
VITE_APP_NAME="PLN Mobile Web"
VITE_APP_URL=http://localhost:3000

# API Configuration
VITE_API_BASE_URL=https://dummyjson.com

# Feature Flags
VITE_DEMO_MODE=true

# Analytics (optional)
VITE_GA_ID=
VITE_GTM_ID=

# ===========================================
# Security Notes:
# - .env.local is gitignored (safe for local secrets)
# - All VITE_ vars are exposed to browser (public)
# - Never put sensitive API keys in VITE_ vars
# - Use server-side env vars for sensitive data
# ===========================================
