# ===========================================
# Environment Configuration Example
# ===========================================
#
# Vite loads env files in this order (later overrides earlier):
# 1. .env                 - Base (all environments)
# 2. .env.local           - Local overrides (gitignored)
# 3. .env.[mode]          - Environment specific (.development, .staging, .production)
# 4. .env.[mode].local    - Local environment overrides (gitignored)
#
# Commands:
# - vite dev              → loads .env.development
# - vite build            → loads .env.production
# - vite build --mode staging → loads .env.staging
#
# ===========================================

# Environment: development | staging | production
VITE_ENV=development

# App Configuration
VITE_APP_NAME="PLN Mobile Web"
VITE_APP_URL=http://localhost:5173

# API Configuration
# Primary API
VITE_API_BASE_URL=https://dummyjson.com

# Additional APIs (examples - configure as needed)
# VITE_API_PAYMENT_URL=https://payment-api.example.com

# ===========================================
# Security Notes:
# - .env.local and .env.*.local are gitignored
# - All VITE_ vars are exposed to browser (public)
# - Never put sensitive API keys in VITE_ vars
# ===========================================
